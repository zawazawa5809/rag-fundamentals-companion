# Copy this file to `.env` and fill in your keys before running examples.
# The companion supports two provider paths; pick ONE and configure it below.

# ----------------------------------------------------------------------------
# Provider selection
# ----------------------------------------------------------------------------
# Which backend `clients.get_clients()` uses when RAG_MOCK is not set.
#   anthropic_openai (default) — matches the article narrative for Part 1-5
#   ollama                     — free local alternative (see ADR 0003)
# RAG_PROVIDER=anthropic_openai

# ----------------------------------------------------------------------------
# Path A: Anthropic Claude + OpenAI embeddings (default, paid)
# ----------------------------------------------------------------------------
# Anthropic — generation (Claude API)
# Get one at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OpenAI — embedding (text-embedding-3-small) and Part 4 RAGAs judge (gpt-4o-mini)
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional (Part 3 only): Cohere Rerank API comparison
# Leave blank to skip the API rerank comparison and use only the local cross-encoder.
COHERE_API_KEY=

# ----------------------------------------------------------------------------
# Path B: Ollama + Qwen3 (free, fully local; see ADR 0003)
# ----------------------------------------------------------------------------
# To enable: set RAG_PROVIDER=ollama above, and pre-pull the models:
#   ollama pull qwen3:8b               # generation (~5.2 GB)
#   ollama pull qwen3-embedding:0.6b   # embedding (~639 MB)
# Required RAM (16 GB Mac is the supported target). 8 GB readers can swap in
# qwen3:4b instead (set OLLAMA_GEN_MODEL=qwen3:4b).
#
# Host (default http://localhost:11434). Override only if Ollama runs remotely.
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_GEN_MODEL=qwen3:8b
# OLLAMA_EMBED_MODEL=qwen3-embedding:0.6b
