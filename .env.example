# Copy this file to `.env` and fill in your keys before running examples.
# Both keys are required for the default (non-mock) path.

# Anthropic — generation (Claude API)
# Get one at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OpenAI — embedding only (text-embedding-3-small)
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional (Part 3 only): Cohere Rerank API comparison
# Leave blank to skip the API rerank comparison and use only the local cross-encoder.
COHERE_API_KEY=
